{
  "branch": "design/06-vector-database",
  "endpoint": "POST /search",
  "_seed_corpus": [
    {"doc_id": "d1", "text": "Postgres uses MVCC for concurrency.", "metadata": {"category": "database"}},
    {"doc_id": "d2", "text": "BM25 is a bag-of-words ranking function based on TF and IDF.", "metadata": {"category": "retrieval"}},
    {"doc_id": "d3", "text": "Reciprocal Rank Fusion combines ranked lists from multiple retrievers.", "metadata": {"category": "retrieval"}},
    {"doc_id": "d4", "text": "Connection pooling matters for async workloads.", "metadata": {"category": "database"}}
  ],
  "tests": [
    {
      "id": "smoke-health",
      "type": "smoke",
      "endpoint_override": "GET /health",
      "expected": {"status": 200},
      "weight": 1.0
    },
    {
      "id": "recall-bm25",
      "type": "lifecycle",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "d1", "text": "Postgres uses MVCC for concurrency.", "metadata": {"category": "database"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d2", "text": "BM25 is a bag-of-words ranking function based on TF and IDF.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d3", "text": "Reciprocal Rank Fusion combines ranked lists from multiple retrievers.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d4", "text": "Connection pooling matters for async workloads.", "metadata": {"category": "database"}}}
      ],
      "input": {"query": "what is BM25 and how does it score documents", "k": 3},
      "expected": {
        "instructions": "After indexing 4 documents (see setup), POST /search for 'BM25 scoring' should return d2 as top result.",
        "top_doc": "d2"
      },
      "weight": 3.0
    },
    {
      "id": "recall-mvcc",
      "type": "lifecycle",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "d1", "text": "Postgres uses MVCC for concurrency.", "metadata": {"category": "database"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d2", "text": "BM25 is a bag-of-words ranking function based on TF and IDF.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d3", "text": "Reciprocal Rank Fusion combines ranked lists from multiple retrievers.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d4", "text": "Connection pooling matters for async workloads.", "metadata": {"category": "database"}}}
      ],
      "input": {"query": "how does Postgres handle concurrent reads", "k": 3},
      "expected": {
        "top_doc": "d1"
      },
      "weight": 2.0
    },
    {
      "id": "filter-restricts-results",
      "type": "filter",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "d1", "text": "Postgres uses MVCC for concurrency.", "metadata": {"category": "database"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d2", "text": "BM25 is a bag-of-words ranking function based on TF and IDF.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d3", "text": "Reciprocal Rank Fusion combines ranked lists from multiple retrievers.", "metadata": {"category": "retrieval"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d4", "text": "Connection pooling matters for async workloads.", "metadata": {"category": "database"}}}
      ],
      "input": {"query": "BM25 ranking", "k": 5, "filter": {"category": "database"}},
      "expected": {
        "instructions": "Query is semantically retrieval, filter restricts to category=database. Results MUST contain only d1 and/or d4 (database docs); MUST NOT contain d2 or d3.",
        "results_must_only_contain_doc_ids_in": ["d1", "d4"],
        "results_must_not_contain": ["d2", "d3"]
      },
      "weight": 3.0
    },
    {
      "id": "filter-no-match-empty-array",
      "type": "filter",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "d1", "text": "Postgres uses MVCC for concurrency.", "metadata": {"category": "database"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "d2", "text": "BM25 is a bag-of-words ranking function based on TF and IDF.", "metadata": {"category": "retrieval"}}}
      ],
      "input": {"query": "anything", "filter": {"category": "nonexistent-xyz"}},
      "expected": {
        "instructions": "Filter matches no docs. MUST return 200 with results: [] (empty array). NOT 404.",
        "status": 200,
        "results_must_be_empty": true
      },
      "weight": 1.5
    },
    {
      "id": "upsert-replaces",
      "type": "upsert",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "up1", "text": "old version", "metadata": {"category": "test"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "up1", "text": "NEW version completely different", "metadata": {"category": "test"}}}
      ],
      "endpoint_override": "GET /docs/up1",
      "expected": {
        "instructions": "Two POSTs to /index with the same doc_id 'up1' but different text. After the second, GET /docs/up1 MUST return text='NEW version completely different' (the latest). Score 0 if it returns the old text or 404.",
        "text_must_equal": "NEW version completely different"
      },
      "weight": 3.0
    },
    {
      "id": "upsert-stats-unchanged",
      "type": "upsert",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "us1", "text": "v1", "metadata": {"category": "stats-test"}}},
        {"method": "POST", "path": "/index", "body": {"doc_id": "us1", "text": "v2 different", "metadata": {"category": "stats-test"}}}
      ],
      "endpoint_override": "GET /stats",
      "expected": {
        "instructions": "Two POSTs to /index with the same doc_id. GET /stats MUST show categories['stats-test'] == 1, NOT 2 (a duplicate vector inserted = bug). The doc was upserted, not appended.",
        "stats_test_count": 1
      },
      "weight": 1.5
    },
    {
      "id": "delete-durable-get",
      "type": "lifecycle",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "del1", "text": "I will be deleted", "metadata": {"category": "temp"}}},
        {"method": "DELETE", "path": "/docs/del1", "body": null}
      ],
      "endpoint_override": "GET /docs/del1",
      "expected": {
        "instructions": "After indexing del1 and DELETE /docs/del1, GET /docs/del1 MUST return 404. Delete is durable.",
        "status": 404
      },
      "weight": 1.5
    },
    {
      "id": "delete-durable-search",
      "type": "lifecycle",
      "setup": [
        {"method": "POST", "path": "/index", "body": {"doc_id": "del2", "text": "I will be deleted from search too", "metadata": {"category": "temp"}}},
        {"method": "DELETE", "path": "/docs/del2", "body": null}
      ],
      "input": {"query": "deleted from search", "k": 5},
      "expected": {
        "instructions": "After indexing del2 then deleting it, POST /search MUST NOT return del2 in any result. The delete propagated to the index, not just the metadata table.",
        "results_must_not_contain": ["del2"]
      },
      "weight": 1.0
    },
    {
      "id": "bulk-atomicity",
      "type": "bulk",
      "endpoint_override": "POST /index/bulk",
      "input": {"documents": [
        {"doc_id": "b_ok", "text": "good doc", "metadata": {"category": "bulk-test"}},
        {"doc_id": "b_bad", "text": "", "metadata": {"category": "bulk-test"}}
      ]},
      "expected": {
        "instructions": "Bulk insert with one bad doc (empty text). MUST return 400 (the entire batch fails atomically).",
        "status": 400
      },
      "weight": 1.5
    },
    {
      "id": "bulk-atomicity-no-partial",
      "type": "bulk",
      "setup": [
        {"method": "POST", "path": "/index/bulk", "body": {"documents": [
          {"doc_id": "b_ok2", "text": "good 2", "metadata": {"category": "bulk-test-2"}},
          {"doc_id": "b_bad2", "text": "", "metadata": {"category": "bulk-test-2"}}
        ]}}
      ],
      "endpoint_override": "GET /docs/b_ok2",
      "expected": {
        "instructions": "After a failed bulk insert (one doc had empty text), the FIRST doc 'b_ok2' MUST NOT have been inserted. GET /docs/b_ok2 MUST return 404.",
        "status": 404
      },
      "weight": 2.0
    },
    {
      "id": "bulk-success",
      "type": "bulk",
      "endpoint_override": "POST /index/bulk",
      "input": {"documents": [
        {"doc_id": "bs_1", "text": "first good", "metadata": {"category": "bulk-good"}},
        {"doc_id": "bs_2", "text": "second good", "metadata": {"category": "bulk-good"}}
      ]},
      "expected": {
        "instructions": "All docs valid. MUST return 200 with indexed_count=2 and doc_ids containing both 'bs_1' and 'bs_2'.",
        "status_in": [200, 201],
        "indexed_count": 2
      },
      "weight": 1.0
    }
  ]
}
